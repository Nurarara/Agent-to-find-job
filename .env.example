# ── Job Board APIs ────────────────────────────────────────────────────────────
# Adzuna: https://developer.adzuna.com/ (free)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# Reed.co.uk: https://www.reed.co.uk/developers (free)
REED_API_KEY=your_reed_api_key

# SerpAPI (Google Jobs): https://serpapi.com/ (250 free/month)
SERPAPI_KEY=your_serpapi_key

# ── AI ────────────────────────────────────────────────────────────────────────
# Google Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── LinkedIn ──────────────────────────────────────────────────────────────────
# How to get your session cookie:
# 1. Log into LinkedIn in Chrome
# 2. Open DevTools → Application → Cookies → linkedin.com
# 3. Copy the value of the 'li_at' cookie
LINKEDIN_SESSION_COOKIE=your_li_at_cookie_value

# ── Applicant details (used for ATS form fields) ──────────────────────────────
APPLICANT_EMAIL=your_email@example.com
APPLICANT_PHONE=+440000000000
APPLICANT_LINKEDIN=https://www.linkedin.com/in/your-profile
APPLICANT_GITHUB=https://github.com/your-username
APPLICANT_PORTFOLIO=
APPLICANT_LOCATION=London, UK
